---
layout: default
---
<!doctype html>
<div class="post">
  <header class="post-header">
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    <div class="clearfix">{{ content }}</div>

    {% assign show_news = page.news and site.announcements.enabled %}
    {% assign show_selected_papers = page.selected_papers %}
    {% assign show_invited_talks = page.invited_talks %}
    {% assign show_repositories = page.repositories and site.data.repositories.github_repos %}
    {% assign show_social = page.social %}
    {% assign has_rendered_section = false %}

    <!-- News -->
    {% if show_news %}
      {% if has_rendered_section %}
        <hr class="section-divider">
      {% endif %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a>
      </h2>
      {% include news.liquid limit=true %}
      {% assign has_rendered_section = true %}
    {% endif %}
       
    <!-- Selected papers -->
    {% if show_selected_papers %}
      {% if has_rendered_section %}
        <hr class="section-divider">
      {% endif %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">Selected Publications</a>
      </h2>
      {% include selected_papers.liquid %}
      {% assign has_rendered_section = true %}
    {% endif %}

    <!-- Invited talks -->
    {% if show_invited_talks %}
      {% if has_rendered_section %}
        <hr class="section-divider">
      {% endif %}
      <h2>Feature Talks</h2>
        <ul class="talks-list">
            {% for talk in site.data.talks %}
            <li class="talk-item" style="font-size: 1rem; margin-bottom: 1rem;">
                <h3 class="talk-title" style="font-size: 1.1rem; margin-bottom: 0.5rem;">
                {% if talk.url %}
              <a href="{{ talk.url }}" target="_blank" class="talk-link">{{ talk.title }}</a>
                {% else %}
              <span class="talk-title-no-link">{{ talk.title }}</span>
                {% endif %}
                </h3>
                <p class="venue-year">
                <a href="{{ talk.venue_url }}" target="_blank" class="venue-link">{{ talk.conference }}</a> 
                <span class="talk-year">{{ talk.year }}</span>
                </p>
            </li>
            {% endfor %}
        </ul>
      {% assign has_rendered_section = true %}
    {% endif %}
    
    <!-- Software Packages (was Repositories) -->
    {% if show_repositories %}
    {% if has_rendered_section %}
      <hr class="section-divider">
    {% endif %}
    <h2>
        <a href="https://github.com/{{ site.github_username }}" style="color: inherit">Software Packages</a>
    </h2>
    <div class="repositories d-flex flex-wrap justify-content-start" style="gap: 5px;">
        {% for repo in site.data.repositories.github_repos %}
        <div style="flex: 1 1 100%; max-width: 80%; box-sizing: border-box; margin-bottom: 5px;">
            {% include repository/repo.liquid repository=repo %}
        </div>
        {% endfor %}
    </div>
    {% assign has_rendered_section = true %}
    {% endif %}

    <!-- Social -->
    {% if show_social %}
      {% if has_rendered_section %}
        <hr class="section-divider">
      {% endif %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>
        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}
  </article>
</div>
